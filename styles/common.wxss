/* styles/common.wxss - 通用样式 */

:root {
  /* 色彩系统 */
  --color-primary: #FF6B35;
  --color-primary-light: #FFF2E8;
  --color-secondary: #52C41A;
  --color-success: #52C41A;
  --color-warning: #FAAD14;
  --color-danger: #FF4D4F;
  --color-info: #1890FF;
  
  /* 文本颜色 */
  --color-text-primary: #333333;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-text-white: #FFFFFF;
  
  /* 背景颜色 */
  --color-bg: #F8F9FA;
  --color-bg-light: #F5F5F5;
  --color-bg-white: #FFFFFF;
  --color-bg-card: #FFFFFF;
  
  /* 边框颜色 */
  --color-border: #E5E5E5;
  --color-border-light: #F0F0F0;
  
  /* 圆角 */
  --border-radius-xs: 4rpx;
  --border-radius-sm: 8rpx;
  --border-radius-md: 12rpx;
  --border-radius-lg: 16rpx;
  --border-radius-xl: 20rpx;
  --border-radius-full: 9999rpx;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  
  /* 间距 */
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 60rpx;
}

/* 基础容器 */
.container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: var(--spacing-md);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

/* 表单容器 */
.form-container {
  background: var(--color-bg-card);
  border-radius: var(--border-radius-xl);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

/* 表单组 */
.form-group {
  margin-bottom: var(--spacing-md);
}

/* 表单标签 */
.label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
}

/* 输入框 */
.input, .textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--border-radius-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-white);
}

.input:focus, .textarea:focus {
  border-color: var(--color-primary);
  outline: none;
}

.textarea {
  min-height: 120rpx;
  resize: vertical;
}

/* 字符计数 */
.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
}

/* 按钮样式 */
.btn {
  padding: 24rpx;
  border-radius: var(--border-radius-md);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.btn-secondary {
  background: var(--color-bg-light);
  color: var(--color-text-secondary);
}

.btn-success {
  background: var(--color-success);
  color: var(--color-text-white);
}

.btn-warning {
  background: var(--color-warning);
  color: var(--color-text-white);
}

.btn-danger {
  background: var(--color-danger);
  color: var(--color-text-white);
}

/* 操作按钮容器 */
.action-buttons {
  display: flex;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-lg);
}

/* 卡片样式 */
.card {
  background: var(--color-bg-card);
  border-radius: var(--border-radius-xl);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--spacing-md);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式适配 */
@media (min-width: 768px) {
  .container {
    padding: var(--spacing-xl);
  }
  
  .form-container, .card {
    padding: var(--spacing-lg);
  }
}