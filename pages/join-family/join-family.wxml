<!-- 暖圆小铺 - 加入家庭 -->
<view class="page-container">
  <!-- 表单区域 -->
  <view class="form-container">
    <view class="form-item">
      <view class="form-label">邀请码</view>
      <input 
        class="form-input" 
        placeholder="请输入家庭邀请码"
        value="{{inviteCode}}"
        bindinput="onInviteCodeInput"
        maxlength="6"
      />
      <view class="form-hint">邀请码由6位字母和数字组成</view>
    </view>

    <view class="tips">
      <view class="tips-title">如何获取邀请码？</view>
      <view class="tips-list">
        <view class="tips-item">• 联系家庭创建者</view>
        <view class="tips-item">• 家庭创建者可在个人中心查看邀请码</view>
        <view class="tips-item">• 邀请码长期有效</view>
      </view>
    </view>
  </view>

  <!-- 底部按钮区域 -->
  <view class="bottom-buttons">
    <view class="btn cancel-btn" bindtap="onCancel">取消</view>
    <view class="btn join-btn" bindtap="onJoin">加入</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加入中...</text>
    </view>
  </view>
</view>