/* pages/join-family/join-family.wxss */

.container {
  max-width: 600rpx;
  margin: 0 auto;
}

.header {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.form-container {
  background: var(--color-bg-card);
  border-radius: var(--border-radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-lg);
}

.input-section {
  margin-bottom: var(--spacing-xl);
}

.label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  font-weight: 500;
  text-align: center;
}

.input {
  width: 100%;
  padding: var(--spacing-lg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--border-radius-lg);
  font-size: 36rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-white);
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: bold;
  font-family: monospace;
  transition: all var(--duration-normal) ease;
}

.input:focus {
  border-color: var(--color-primary);
  outline: none;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
}

.hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-sm);
}

.or-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: var(--spacing-xl) 0;
}

.line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.or-text {
  padding: 0 var(--spacing-md);
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-card);
}

.scan-section {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.scan-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-lg);
  background: transparent;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--border-radius-lg);
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 500;
  transition: all var(--duration-normal) ease;
}

.scan-btn:hover {
  background: var(--color-primary-light);
  transform: translateY(-2rpx);
}

.scan-btn:active {
  transform: translateY(0);
}

.scan-icon {
  font-size: 32rpx;
}

.scan-text {
  font-size: 28rpx;
}

.family-info {
  margin-top: var(--spacing-xl);
  animation: fadeIn var(--duration-normal) ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.info-card {
  background: var(--color-primary-light);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-lg);
  border-left: 4rpx solid var(--color-primary);
}

.info-title {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid rgba(255, 107, 53, 0.2);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid rgba(255, 107, 53, 0.1);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.action-buttons {
  margin-top: var(--spacing-xl);
}

.join-btn {
  width: 100%;
  padding: var(--spacing-lg);
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--border-radius-md);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 2rpx;
  transition: all var(--duration-normal) ease;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.join-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 53, 0.4);
}

.join-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.2);
}

.join-btn[loading] {
  opacity: 0.8;
}

@media (min-width: 768px) {
  .container {
    max-width: 800rpx;
  }
  
  .form-container {
    padding: var(--spacing-xl);
  }
  
  .input {
    padding: var(--spacing-xl) var(--spacing-lg);
    font-size: 48rpx;
  }
  
  .join-btn {
    padding: var(--spacing-xl) var(--spacing-lg);
    font-size: 36rpx;
  }
}