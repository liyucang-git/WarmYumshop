<!-- 暖圆小铺 - 创建家庭 -->
<view class="page-container">
  <!-- 表单区域 -->
  <view class="form-container">
    <view class="form-item">
      <view class="form-label">家庭名称</view>
      <input 
        class="form-input" 
        placeholder="请输入家庭名称（2-20个字符）"
        value="{{familyName}}"
        bindinput="onFamilyNameInput"
        maxlength="20"
      />
      <view class="form-hint">为你的家庭起一个温馨的名字</view>
    </view>

    <view class="tips">
      <view class="tips-title">创建家庭后，你可以：</view>
      <view class="tips-list">
        <view class="tips-item">• 邀请家庭成员加入</view>
        <view class="tips-item">• 共同管理家庭菜品</view>
        <view class="tips-item">• 分享美食瞬间</view>
      </view>
    </view>
  </view>

  <!-- 底部按钮区域 -->
  <view class="bottom-buttons">
    <view class="btn cancel-btn" bindtap="onCancel">取消</view>
    <view class="btn create-btn" bindtap="onCreate">创建</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">创建中...</text>
    </view>
  </view>
</view>