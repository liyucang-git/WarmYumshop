/* 暖圆小铺 - 创建家庭样式 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(to right, #FF6B35, #FF8E62);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-left,
.header-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: white;
  font-weight: 600;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  line-height: 1.2;
}

.create-btn {
  font-size: 28rpx;
  font-weight: 500;
  color: white;
  line-height: 1.2;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
  white-space: nowrap;
}

.create-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 表单容器 */
.form-container {
  padding: 24rpx;
}

/* 表单项 */
.form-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.form-input {
  width: 100%;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
  border: none;
  border-bottom: 1rpx solid #E5E5E5;
  outline: none;
  margin-bottom: 12rpx;
}

.form-input::placeholder {
  color: #999999;
}

.form-hint {
  font-size: 20rpx;
  color: #999999;
  line-height: 1.2;
}

/* 提示信息 */
.tips {
  background-color: #FFF2E8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 32rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #FF6B35;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #666666;
  line-height: 1.4;
}

/* 加载中 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 240rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E5E5E5;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.2;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .form-container {
    padding: 16rpx;
  }
  
  .form-item {
    padding: 20rpx;
    margin-bottom: 16rpx;
  }
  
  .tips {
    padding: 20rpx;
    margin-top: 24rpx;
  }
}

@media (min-width: 750px) {
  .form-container {
    padding: 32rpx;
  }
  
  .form-item {
    padding: 32rpx;
    margin-bottom: 32rpx;
  }
  
  .tips {
    padding: 32rpx;
    margin-top: 40rpx;
  }
}