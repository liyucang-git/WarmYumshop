/* 暖圆小铺 - 修改个人信息样式 */

/* 页面根元素背景色 */
page {
  background-color: #F5F5F5;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(to right, #FF6B35, #FF8E62);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-left,
.header-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: white;
  font-weight: 600;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  line-height: 1.2;
}

/* 主要内容区 */
.content {
  padding: 24rpx;
}

/* 个人信息项 */
.profile-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  width: 120rpx;
}

/* 头像容器 */
.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  cursor: pointer;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-text {
  font-size: 20rpx;
  color: white;
}

/* 输入框 */
.item-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  padding: 8rpx 0;
  text-align: right;
}

.item-input::placeholder {
  color: #999999;
}

/* 保存按钮 */
.save-btn {
  background-color: #FF6B35;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 32rpx;
  text-align: center;
  margin-top: 48rpx;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.save-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 加载中提示 */
.loading-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E5E5E5;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #333333;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .header {
    padding: 20rpx;
  }
  
  .content {
    padding: 16rpx;
  }
  
  .profile-item {
    padding: 20rpx;
    margin-bottom: 16rpx;
  }
  
  .save-btn {
    padding: 20rpx;
    margin-top: 32rpx;
  }
  
  .avatar-container {
    width: 100rpx;
    height: 100rpx;
  }
}

@media (min-width: 750px) {
  .header {
    padding: 32rpx;
  }
  
  .content {
    padding: 32rpx;
  }
  
  .profile-item {
    padding: 28rpx;
    margin-bottom: 32rpx;
  }
  
  .save-btn {
    padding: 28rpx;
    margin-top: 64rpx;
  }
  
  .avatar-container {
    width: 140rpx;
    height: 140rpx;
  }
}