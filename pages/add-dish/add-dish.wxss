/* 暖圆小铺 - 添加菜品样式 */

/* 页面根元素背景色 */
page {
  background-color: #F5F5F5;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 底部按钮区域 */
.bottom-buttons {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background-color: white;
  border-top: 1rpx solid #E5E5E5;
  position: sticky;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.btn {
  flex: 1;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.cancel-btn {
  background-color: #F5F5F5;
  color: #666666;
  border: 1rpx solid #E5E5E5;
}

.save-btn {
  background-color: #FF6B35;
  color: white;
}

.cancel-btn:active {
  background-color: #E5E5E5;
  transform: scale(0.98);
}

.save-btn:active {
  background-color: #E55A24;
  transform: scale(0.98);
}

/* 表单容器 */
.form-container {
  padding: 24rpx;
}

/* 表单项 */
.form-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

/* 图片上传 */
.image-uploader {
  width: 100%;
  min-height: 320rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  position: relative;
  width: 100%;
  height: 320rpx;
  background-color: #F5F5F5;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.remove-image:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.upload-btn {
  width: 100%;
  height: 320rpx;
  border: 2rpx dashed #E5E5E5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  background-color: #F9F9F9;
}

.upload-btn:active {
  background-color: #F0F0F0;
  transform: scale(0.99);
}

.upload-icon {
  font-size: 64rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.2;
}

/* AI生成图片 */
.ai-generate-section {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.ai-generate-btn {
  width: 100%;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.ai-generate-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.ai-generate-btn[disabled] {
  background: #E5E5E5;
  color: #999999;
  cursor: not-allowed;
}

.ai-tip {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.2;
}

/* 输入框 */
.form-input {
  width: 100%;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
  border: none;
  border-bottom: 1rpx solid #E5E5E5;
  outline: none;
}

.form-input::placeholder {
  color: #999999;
}

/* 分类选择器 */
.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.category-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background-color: #F5F5F5;
  color: #666666;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.category-item.selected {
  background-color: #FF6B35;
  color: white;
}

.category-item:active:not(.selected) {
  background-color: #E5E5E5;
  transform: scale(0.95);
}

.category-item.selected:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
  border: 1rpx solid #E5E5E5;
  border-radius: 8rpx;
  outline: none;
  min-height: 120rpx;
  resize: none;
}

.form-textarea::placeholder {
  color: #999999;
}

/* 加载中 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 240rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E5E5E5;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.2;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .form-container {
    padding: 16rpx;
  }
  
  .form-item {
    padding: 20rpx;
    margin-bottom: 16rpx;
  }
  
  .image-preview,
  .upload-btn {
    height: 280rpx;
  }
}

@media (min-width: 750px) {
  .form-container {
    padding: 32rpx;
  }
  
  .form-item {
    padding: 32rpx;
    margin-bottom: 32rpx;
  }
  
  .image-preview,
  .upload-btn {
    height: 400rpx;
  }
}
