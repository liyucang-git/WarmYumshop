/* pages/dish-detail/dish-detail.wxss */

.container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 菜品图片区域 */
.dish-images {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.dish-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.image-count {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 菜品基本信息 */
.dish-info-section {
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.dish-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 10rpx;
  line-height: 1.2;
}

.dish-description {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.dish-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.dish-category {
  background: var(--color-primary-light);
  color: var(--color-primary);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.dish-difficulty {
  background: var(--color-success-light);
  color: var(--color-success);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.dish-time {
  background: var(--color-warning-light);
  color: var(--color-warning);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.dish-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.dish-stat-item {
  display: flex;
  align-items: center;
}

.dish-stat-icon {
  width: 24rpx;
  height: 24rpx;
  color: var(--color-text-tertiary);
  margin-right: 8rpx;
}

.dish-stat-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 作者信息 */
.author-section {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: var(--color-bg-light);
  border-radius: 20rpx;
  margin: 20rpx;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.author-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.author-date {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 食材清单 */
.ingredients-section {
  padding: 30rpx;
  background: #FFFFFF;
  border-radius:, 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title-text {
  flex: 1;
}

.copy-btn {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.ingredients-list {
  margin-top: 20rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.ingredient-amount {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* 烹饪步骤 */
.steps-section {
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.steps-list {
  margin-top: 20rpx;
}

.step-item {
  display: flex;
  margin-bottom: 30rpx;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-description {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.step-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
  margin-top: 10rpx;
}

/* 烹饪小贴士 */
.tips-section {
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tips-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
  padding: 20rpx;
  background: var(--color-bg-light);
  border-radius: 12rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #FFFFFF;
  border-top: 1rpx solid var(--color-border);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.favorite-btn {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn .icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.edit-btn {
  background: var(--color-warning);
  color: #FFFFFF;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.delete-btn {
  background: var(--color-danger);
  color: #FFFFFF;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式适配 */
@media (min-width: 768px) {
  .dish-images {
    height: 500rpx;
  }
  
  .dish-image {
    height: 500rpx;
  }
  
  .dish-info-section,
  .ingredients-section,
  .steps-section,
  .tips-section {
    margin: 40rpx;
    padding: 40rpx;
  }
  
  .action-bar {
    padding: 40rpx;
  }
}