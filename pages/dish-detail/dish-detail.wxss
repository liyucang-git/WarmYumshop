/* 暖圆小铺 - 菜品详情样式 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}



/* 菜品图片 */
.image-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  background-color: #F5F5F5;
  overflow: hidden;
  cursor: pointer;
}

.dish-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.image-container:active .dish-image {
  transform: scale(1.05);
}

.preview-hint {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

/* 菜品信息 */
.info-container {
  background-color: white;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 菜名 */
.dish-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  line-height: 1.2;
}

/* 分类标签 */
.dish-categories {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.category-tag {
  background-color: #FFF2E8;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.category-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #FF6B35;
  line-height: 1.2;
}

/* 时间信息 */
.time-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.time-icon {
  font-size: 24rpx;
  color: #999999;
}

.time-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.2;
}

/* 描述 */
.dish-description {
  margin-top: 24rpx;
}

.desc-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.desc-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background-color: white;
  margin: 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: sticky;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 90;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #FF6B35;
  color: white;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #333333;
  border: 1rpx solid #E5E5E5;
}

.btn-secondary:active {
  background-color: #E5E5E5;
  transform: scale(0.98);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .info-container {
    margin: 16rpx;
    padding: 24rpx;
  }
  
  .action-buttons {
    padding: 16rpx;
    gap: 16rpx;
  }
  
  .image-container {
    height: 320rpx;
  }
  
  .dish-name {
    font-size: 32rpx;
  }
}

@media (min-width: 750px) {
  .info-container {
    margin: 32rpx;
    padding: 40rpx;
  }
  
  .action-buttons {
    padding: 32rpx;
    gap: 32rpx;
  }
  
  .image-container {
    height: 500rpx;
  }
  
  .dish-name {
    font-size: 40rpx;
  }
}