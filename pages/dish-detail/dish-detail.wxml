<!-- 暖圆小铺 - 菜品详情 -->
<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left" bindtap="onBack">
      <view class="back-icon">←</view>
    </view>
    <view class="header-title">{{dish.name || '菜品详情'}}</view>
    <view class="header-right" bindtap="showActionMenu">
      <view class="action-icon">•••</view>
    </view>
  </view>

  <!-- 菜品图片 -->
  <view class="image-container" bindtap="previewImage">
    <image 
      class="dish-image" 
      src="{{dish.imageUrl || '/images/default-dish.png'}}"
      mode="aspectFill"
    />
    <view class="preview-hint">点击查看大图</view>
  </view>

  <!-- 菜品信息 -->
  <view class="info-container">
    <!-- 菜名 -->
    <view class="dish-name">{{dish.name}}</view>
    
    <!-- 分类标签 -->
    <view class="dish-categories">
      <view 
        wx:for="{{dish.categories}}"
        wx:key="index"
        class="category-tag"
        bindtap="onCategoryTap"
        data-category="{{item}}"
      >
        <text class="category-text">{{item}}</text>
      </view>
    </view>
    
    <!-- 时间信息 -->
    <view class="time-info" wx:if="{{dish.formattedTime}}">
      <text class="time-icon">🕐</text>
      <text class="time-text">添加时间：{{dish.formattedTime}}</text>
    </view>
    
    <!-- 描述 -->
    <view class="dish-description" wx:if="{{dish.description}}">
      <view class="desc-title">描述</view>
      <view class="desc-content">{{dish.description}}</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <view class="btn btn-primary" bindtap="onEdit">编辑</view>
    <view class="btn btn-secondary" bindtap="onDelete">删除</view>
  </view>

  <!-- 操作菜单 -->
  <action-sheet
    bindchange="onActionSheetChange"
    hidden="{{!showActionSheet}}"
  >
    <action-sheet-item bindtap="onEdit">编辑</action-sheet-item>
    <action-sheet-item bindtap="onDelete">删除</action-sheet-item>
    <action-sheet-cancel>取消</action-sheet-cancel>
  </action-sheet>

  <!-- 确认删除弹窗 -->
  <modal
    title="确认删除"
    confirm-text="删除"
    cancel-text="取消"
    bindconfirm="onDeleteConfirm"
    bindcancel="onDeleteCancel"
    hidden="{{!showDeleteDialog}}"
  >
    确定要删除这个菜品吗？删除后无法恢复。
  </modal>
</view>