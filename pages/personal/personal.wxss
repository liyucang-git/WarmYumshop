/* pages/personal/personal.wxss */

.container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 用户信息卡片 */
.user-info-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: 0 0 40rpx 40rpx;
  padding: 60rpx 40rpx 40rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.user-info-card::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-info-card::after {
  content: '';
  position: absolute;
  bottom: -50rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.user-avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-name-section {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  line-height: 1.2;
}

.user-bio {
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.4;
}

.edit-profile-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
}

.edit-profile-btn::after {
  content: '→';
  margin-left: 8rpx;
  transition: transform 0.3s;
}

.edit-profile-btn:hover::after {
  transform: translateX(4rpx);
}

/* 家庭信息卡片 */
.family-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: -20rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.family-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.family-icon {
  width: 60rpx;
  height: 60rpx;
  background: var(--color-primary-light);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.family-icon .icon {
  width: 32rpx;
  height: 32rpx;
  color: var(--color-primary);
}

.family-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.family-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-info {
  flex: 1;
}

.family-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.family-members {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.family-action {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 菜单列表 */
.menu-section {
  padding: 0 30rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: var(--color-bg-hover);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  background: var(--color-bg-light);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon .icon {
  width: 32rpx;
  height: 32rpx;
  color: var(--color-primary);
}

.menu-content {
  flex: 1;
}

.menu-title-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  font-weight: 500;
}

.menu-description {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  color: var(--color-text-tertiary);
}

/* 空状态 */
.empty-family {
  text-align: center;
  padding: 40rpx 0;
}

.empty-family-icon {
  width: 100rpx;
  height: 100rpx;
  background: var(--color-bg-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.empty-family-icon .icon {
  width: 48rpx;
  height: 48rpx;
  color: var(--color-text-tertiary);
}

.empty-family-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.create-family-btn {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: inline-block;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式适配 */
@media (min-width: 768px) {
  .user-info-card {
    border-radius: 0 0 60rpx 60rpx;
    padding: 80rpx 60rpx 60rpx;
  }
  
  .family-card {
    margin: -30rpx 60rpx 40rpx;
  }
  
  .menu-section {
    padding: 0 60rpx;
  }
}