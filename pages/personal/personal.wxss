/* 暖圆小铺 - 个人中心样式 */

/* 页面根元素背景色 */
page {
  background-color: #F5F5F5;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 用户信息区 */
.user-info-section {
  background-color: white;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  cursor: pointer;
  transition: all 0.3s ease;
}

.user-info-section:active {
  background-color: #F9F9F9;
  transform: scale(0.99);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background-color: #F5F5F5;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
}

.user-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.user-status {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.2;
}

.arrow-icon {
  font-size: 28rpx;
  color: #999999;
}

/* 家庭信息区 */
.family-section {
  background-color: white;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.2;
}

.section-action {
  font-size: 24rpx;
  color: #FF6B35;
  line-height: 1.2;
  cursor: pointer;
}

.family-info {
  padding: 24rpx 32rpx;
}

.family-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.family-members {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.2;
}

.family-invite {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E5E5E5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.invite-code {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.2;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background-color: #FF6B35;
  color: white;
  font-size: 20rpx;
  font-weight: 500;
  border-radius: 16rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}

.copy-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 无家庭时的引导区 */
.no-family-section {
  background-color: white;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.no-family-content {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.no-family-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.no-family-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.2;
  text-align: center;
}

.no-family-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

/* 其他操作区 */
.action-section {
  background-color: white;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
  cursor: pointer;
  transition: all 0.3s ease;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background-color: #F9F9F9;
  transform: scale(0.99);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.2;
}

/* 按钮样式 */
.btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #FF6B35;
  color: white;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #333333;
  border: 1rpx solid #E5E5E5;
}

.btn-secondary:active {
  background-color: #E5E5E5;
  transform: scale(0.95);
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.login-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  width: 80%;
  max-width: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.2;
  text-align: center;
}

.login-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
  text-align: center;
}

.login-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #FF6B35;
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  border-radius: 32rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}

.login-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.cancel-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #F5F5F5;
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  border-radius: 32rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}

.cancel-btn:active {
  background-color: #E5E5E5;
  transform: scale(0.95);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .user-info-section {
    margin: 16rpx;
    padding: 24rpx;
  }
  
  .family-section,
  .no-family-section,
  .action-section {
    margin: 0 16rpx 16rpx;
  }
  
  .section-header {
    padding: 20rpx 24rpx;
  }
  
  .family-info,
  .family-invite {
    padding: 20rpx 24rpx;
  }
  
  .action-item {
    padding: 20rpx 24rpx;
  }
}

@media (min-width: 750px) {
  .user-info-section {
    margin: 32rpx;
    padding: 40rpx;
  }
  
  .family-section,
  .no-family-section,
  .action-section {
    margin: 0 32rpx 32rpx;
  }
  
  .section-header {
    padding: 28rpx 40rpx;
  }
  
  .family-info,
  .family-invite {
    padding: 28rpx 40rpx;
  }
  
  .action-item {
    padding: 28rpx 40rpx;
  }
}