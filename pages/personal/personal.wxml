<!-- жҡ–еңҶе°Ҹй“ә - дёӘдәәдёӯеҝғ -->
<view class="page-container">
  <!-- йЎ¶йғЁеҜјиҲӘж Ҹ -->
  <view class="header">
    <view class="header-title">дёӘдәәдёӯеҝғ</view>
  </view>

  <!-- з”ЁжҲ·дҝЎжҒҜеҢә -->
  <view class="user-info-section" bindtap="onUserInfoTap">
    <view class="user-avatar">
      <image 
        class="avatar-image" 
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
    </view>
    <view class="user-details">
      <view class="user-nickname">{{userInfo.nickname || 'зӮ№еҮ»зҷ»еҪ•'}}</view>
      <view class="user-status">{{userInfo.nickname ? 'е·Ізҷ»еҪ•' : 'жңӘзҷ»еҪ•'}}</view>
    </view>
    <view class="arrow-icon" wx:if="{{userInfo && userInfo.nickname}}">></view>
  </view>

  <!-- дёӘдәәдҝЎжҒҜзј–иҫ‘еҢә -->
  <view class="action-section" wx:if="{{userInfo && userInfo.nickname}}">
    <view class="section-header">
      <view class="section-title">дёӘдәәдҝЎжҒҜ</view>
    </view>
    <view class="action-item" bindtap="onEditProfileTap">
      <view class="action-icon">вңҸпёҸ</view>
      <view class="action-text">дҝ®ж”№дёӘдәәдҝЎжҒҜ</view>
      <view class="arrow-icon">></view>
    </view>
  </view>

  <!-- е®¶еәӯдҝЎжҒҜеҢә -->
  <view class="family-section" wx:if="{{userInfo.familyId}}">
    <view class="section-header">
      <view class="section-title">жҲ‘зҡ„е®¶еәӯ</view>
      <view class="section-action" bindtap="goToFamilyManagement">з®ЎзҗҶ ></view>
    </view>
    <view class="family-info">
      <view class="family-name">{{familyInfo.name || 'еҠ иҪҪдёӯ...'}}</view>
      <view class="family-members">{{familyInfo.members ? familyInfo.members.length + ' дҪҚжҲҗе‘ҳ' : 'еҠ иҪҪдёӯ...'}}</view>
    </view>
    <view class="family-invite">
      <view class="invite-code">йӮҖиҜ·з Ғ: {{familyInfo.inviteCode || 'еҠ иҪҪдёӯ...'}}</view>
      <view class="copy-btn" bindtap="copyInviteCode">еӨҚеҲ¶</view>
    </view>
  </view>

  <!-- ж— е®¶еәӯж—¶зҡ„еј•еҜјеҢә -->
  <view class="no-family-section" wx:else>
    <view class="section-header">
      <view class="section-title">жҲ‘зҡ„е®¶еәӯ</view>
    </view>
    <view class="no-family-content">
      <view class="no-family-icon">рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ</view>
      <view class="no-family-text">иҝҳжІЎжңүеҠ е…Ҙе®¶еәӯ</view>
      <view class="no-family-buttons">
        <button class="btn btn-primary" bindtap="goToCreateFamily">еҲӣе»әе®¶еәӯ</button>
        <button class="btn btn-secondary" bindtap="goToJoinFamily">еҠ е…Ҙе®¶еәӯ</button>
      </view>
    </view>
  </view>

  <!-- е…¶д»–ж“ҚдҪңеҢә -->
  <view class="action-section">
    <view class="section-header">
      <view class="section-title">е…¶д»–</view>
    </view>
    <view class="action-item" bindtap="onLogoutTap">
      <view class="action-icon">рҹҡӘ</view>
      <view class="action-text">йҖҖеҮәзҷ»еҪ•</view>
      <view class="arrow-icon">></view>
    </view>
    <view class="action-item" bindtap="onAboutTap">
      <view class="action-icon">в„№пёҸ</view>
      <view class="action-text">е…ідәҺ</view>
      <view class="arrow-icon">></view>
    </view>
  </view>

  <!-- зҷ»еҪ•еј№зӘ— -->
  <view class="login-modal" wx:if="{{showLoginModal}}">
    <view class="login-content">
      <view class="login-title">зҷ»еҪ•жҡ–еңҶе°Ҹй“ә</view>
      <view class="login-desc">йҖҡиҝҮеҫ®дҝЎзҷ»еҪ•пјҢејҖе§ӢдҪҝз”Ёжҡ–еңҶе°Ҹй“ә</view>
      <button 
        class="login-btn" 
        open-type="getUserInfo"
        bindgetuserinfo="onGetUserInfo"
      >
        еҫ®дҝЎзҷ»еҪ•
      </button>
      <button class="cancel-btn" bindtap="closeLoginModal">еҸ–ж¶Ҳ</button>
    </view>
  </view>
</view>