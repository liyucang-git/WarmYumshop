<!-- 暖圆小铺 - 家庭管理 -->
<view class="page-container">
  <!-- 家庭信息 -->
  <view class="family-info-section">
    <view class="family-name-section">
      <view wx:if="{{!editingName}}" class="family-name-display">
        <text class="family-name">{{familyInfo.name}}</text>
        <view wx:if="{{userRole === 'creator'}}" class="edit-name-btn" bindtap="startEditName">
          <text class="edit-icon">✏️</text>
        </view>
      </view>
      <view wx:else class="family-name-edit">
        <input 
          class="family-name-input" 
          value="{{newFamilyName}}" 
          bindinput="onFamilyNameInput" 
          placeholder="请输入家庭名称"
          maxlength="20"
        />
        <view class="edit-actions">
          <view class="cancel-edit-btn" bindtap="cancelEditName">取消</view>
          <view class="save-name-btn" bindtap="saveFamilyName">保存</view>
        </view>
      </view>
    </view>
    <view class="invite-code-section">
      <view class="invite-code-label">邀请码</view>
      <view class="invite-code-content">
        <text class="invite-code">{{familyInfo.inviteCode}}</text>
        <view class="copy-btn" bindtap="copyInviteCode">复制</view>
      </view>
      <view class="invite-hint">分享邀请码给家人，邀请他们加入</view>
      <view class="invite-friend-btn" bindtap="inviteFriend">
        <text class="invite-friend-text">邀请微信好友</text>
      </view>
    </view>
  </view>

  <!-- 成员列表 -->
  <view class="members-section">
    <view class="section-header">
      <view class="section-title">家庭成员</view>
      <view class="member-count">{{familyInfo.members ? familyInfo.members.length : 0}} 人</view>
    </view>
    <view class="members-list">
      <view 
        wx:for="{{members}}"
        wx:key="userId"
        class="member-item"
      >
        <view class="member-avatar">
          <image 
            class="avatar-image" 
            src="{{item.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
          />
        </view>
        <view class="member-info">
          <view class="member-name">{{item.nickname}}</view>
          <view class="member-role">{{item.role === 'creator' ? '创建者' : '成员'}}</view>
        </view>
        <view class="member-actions" wx:if="{{userRole === 'creator' && item.role !== 'creator'}}">
          <view class="remove-btn" bindtap="removeMember" data-userid="{{item.userId}}">
            移除
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <view class="btn btn-danger" bindtap="showLeaveConfirm" wx:if="{{userRole !== 'creator'}}">
      离开家庭
    </view>
    <view class="btn btn-danger" bindtap="showDissolveConfirm" wx:if="{{userRole === 'creator'}}">
      解散家庭
    </view>
  </view>

  <!-- 确认弹窗 -->
  <modal
    title="{{confirmDialogTitle}}"
    confirm-text="确认"
    cancel-text="取消"
    hidden="{{!showConfirmDialog}}"
    bindconfirm="onConfirmAction"
    bindcancel="onCancelAction"
  >
    {{confirmDialogContent}}
  </modal>
</view>