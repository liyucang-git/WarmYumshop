/* 暖圆小铺 - 首页样式 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--color-background);
}

/* 顶部导航栏 */
.header {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-border);
  padding: 24rpx 24rpx 16rpx;
}

.header-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 8rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-surface-tint);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--duration-fast) ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 分类筛选区 */
.category-scroll {
  white-space: nowrap;
  background-color: var(--color-surface);
  padding: 0 24rpx 16rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-background);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  font-weight: 500;
  cursor: pointer;
  transition: all var(--duration-fast) ease;
  user-select: none;
}

.category-item.active {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
}

.category-item:not(.active):active {
  opacity: 0.8;
  transform: scale(0.95);
}

.category-text {
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
}

/* 菜品列表区 */
.dish-scroll {
  height: calc(100vh - 200rpx);
  padding: 16rpx 24rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  text-align: center;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
  font-weight: 500;
}

.empty-btn {
  padding: 16rpx 48rpx;
  font-size: var(--font-size-md);
  font-weight: 500;
}

/* 加载中状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* 网格视图 */
.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.dish-grid-item {
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) ease;
  cursor: pointer;
}

.dish-grid-item:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: var(--shadow-xs);
}

/* 菜品图片容器 */
.dish-image-container {
  position: relative;
  width: 100%;
  height: 240rpx;
  overflow: hidden;
  background: linear-gradient(135deg, var(--color-surface-tint) 0%, var(--color-surface) 100%);
}

.dish-image {
  width: 100%;
  height: 100%;
  transition: opacity var(--duration-normal) ease;
}

.image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-background);
}

.placeholder-content {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, var(--color-border) 25%, var(--color-border-light) 50%, var(--color-border) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 菜品信息 */
.dish-info {
  padding: 16rpx;
}

.dish-name {
  margin-bottom: 8rpx;
}

.name-text {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 菜品标签 */
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.dish-tag {
  background-color: var(--color-surface-tint);
  border-radius: var(--radius-xs);
  padding: 4rpx 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag-text {
  font-size: var(--font-size-xs);
  font-weight: 400;
  color: var(--color-primary);
  line-height: 1.2;
}

.more-tag {
  font-size: var(--font-size-xs);
  font-weight: 400;
  color: var(--color-text-tertiary);
  line-height: 1.2;
}

/* 列表视图 */
.list-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-list-item {
  display: flex;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  cursor: pointer;
  transition: all var(--duration-normal) ease;
}

.dish-list-item:active {
  background-color: var(--color-background);
  opacity: 0.9;
  transform: scale(0.99);
}

.list-image-container {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--color-surface-tint) 0%, var(--color-surface) 100%);
  flex-shrink: 0;
}

.list-image {
  width: 100%;
  height: 100%;
}

.list-info {
  flex: 1;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.list-name {
  margin-bottom: 8rpx;
}

.list-name-text {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient::
  vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.list-tag {
  background-color: var(--color-surface-tint);
  border-radius: var(--radius-xs);
  padding: 2rpx 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.list-tag-text {
  font-size: var(--font-size-xs);
  font-weight: 400;
  color: var(--color-primary);
  line-height: 1.1;
}

.list-time {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.time-icon {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.time-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: 400;
}

/* 加载更多提示 */
.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.no-more-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* 悬浮添加按钮 */
.floating-action-btn {
  position: fixed;
  bottom: 140rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  cursor: pointer;
  z-index: 90;
  transition: all var(--duration-fast) ease;
}

.floating-action-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .header {
    padding: 20rpx 20rpx 14rpx;
  }
  
  .category-scroll {
    padding: 0 20rpx 14rpx;
  }
  
  .dish-scroll {
    padding: 14rpx 20rpx;
  }
  
  .grid-container {
    gap: 12rpx;
  }
}

@media (min-width: 750px) {
  .header {
    padding: 32rpx 32rpx 20rpx;
  }
  
  .category-scroll {
    padding: 0 32rpx 20rpx;
  }
  
  .dish-scroll {
    padding: 20rpx 32rpx;
  }
  
  .grid-container {
    grid-template-columns: repeat(3, 1fr);
    gap: 24rpx;
  }
}