/* 暖圆小铺 - 首页样式 */

/* 页面根元素背景色 */
page {
  background-color: #F5F5F5;
}

/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 顶部内容区 */
.top-content {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(to right, #FF6B35, #FF8E62);
  padding: 24rpx;
  flex-shrink: 0;
}

/* 搜索框和视图切换 */
.search-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  padding: 8rpx 0;
}

.search-placeholder {
  color: #999999;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 分类筛选区 */
.category-scroll {
  white-space: nowrap;
  padding-bottom: 16rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background-color: rgba(255, 255, 255, 0.5);
  color: white;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  user-select: none;
}

.category-item.active {
  background-color: white;
  color: #FF6B35;
}

.category-item:not(.active):active {
  opacity: 0.8;
  transform: scale(0.95);
}

.category-text {
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
}

/* 菜品列表区 */
.dish-scroll {
  height: calc(100vh - 260rpx);
  padding: 16rpx 0;
  width: 100%;
  box-sizing: border-box;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #FFF2E8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 48rpx;
  font-weight: 500;
}

.empty-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: #FF6B35;
  color: white;
  border: none;
  border-radius: 32rpx;
  cursor: pointer;
}

/* 加载中状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E5E5E5;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #999999;
}

/* 网格视图 */
.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx;
}

.dish-grid-item {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  cursor: pointer;
}

.dish-grid-item:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 菜品图片容器 */
.dish-image-container {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #F5F5F5 0%, #FFFFFF 100%);
}

.dish-image {
  width: 100%;
  height: 100%;
  transition: opacity 0.3s ease;
}

.image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
}

.placeholder-content {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #E5E5E5 25%, #F0F0F0 50%, #E5E5E5 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 菜品信息 */
.dish-info {
  padding: 20rpx;
}

.dish-name {
  margin-bottom: 12rpx;
}

.name-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 菜品标签 */
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.dish-tag {
  background-color: #FF6B35;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag-text {
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  line-height: 1.2;
}

.more-tag {
  font-size: 20rpx;
  font-weight: 400;
  color: #999999;
  line-height: 1.2;
}

.dish-time {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.time-text {
  font-size: 20rpx;
  color: #999999;
  line-height: 1.2;
}

/* 列表视图 */
.list-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 0;
}

.dish-list-item {
  display: flex;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  cursor: pointer;
  transition: all 0.3s ease;
}

.dish-list-item:active {
  background-color: #F9F9F9;
  opacity: 0.9;
  transform: scale(0.99);
}

.list-image-container {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #FFFFFF 100%);
  flex-shrink: 0;
}

.list-image {
  width: 100%;
  height: 100%;
}

.list-info {
  flex: 1;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.list-name {
  margin-bottom: 8rpx;
}

.list-name-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.list-tag {
  background-color: #FF6B35;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.list-tag-text {
  font-size: 20rpx;
  font-weight: 500;
  color: white;
  line-height: 1.1;
}

.list-time {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.time-icon {
  font-size: 20rpx;
  color: #999999;
}

.time-text {
  font-size: 20rpx;
  color: #999999;
  font-weight: 400;
}

/* 加载更多提示 */
.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #999999;
}

.no-more-text {
  font-size: 24rpx;
  color: #666666;
}

/* 悬浮添加按钮 */
.floating-action-btn {
  position: fixed;
  bottom: 140rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #FF6B35;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4);
  cursor: pointer;
  z-index: 90;
  transition: all 0.2s ease;
}

.floating-action-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .top-content {
    padding: 20rpx 20rpx 14rpx;
  }
  
  .category-scroll {
    padding: 0 20rpx 14rpx;
  }
  
  .dish-scroll {
    padding: 14rpx 0;
  }
  
  .grid-container {
    padding: 16rpx 20rpx;
    gap: 12rpx;
  }
}

@media (min-width: 750px) {
  .top-content {
    padding: 32rpx 32rpx 20rpx;
  }
  
  .category-scroll {
    padding: 0 32rpx 20rpx;
  }
  
  .dish-scroll {
    padding: 20rpx 0;
  }
  
  .grid-container {
    grid-template-columns: repeat(3, 1fr);
    padding: 20rpx 32rpx;
    gap: 24rpx;
  }
}