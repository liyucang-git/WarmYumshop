<!-- 暖圆小铺 - 首页 -->
<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-title">暖圆小铺</view>
    <view class="header-actions">
      <!-- 视图切换按钮 -->
      <view class="action-btn" bindtap="toggleViewMode">
        <image 
          class="action-icon" 
          src="{{viewMode === 'grid' ? '/images/icons/list.svg' : '/images/icons/grid.svg'}}"
          mode="aspectFit"
        />
      </view>
      <!-- 排序按钮 -->
      <view class="action-btn" bindtap="toggleSortOrder">
        <image 
          class="action-icon" 
          src="{{sortOrder === 'desc' ? '/images/icons/sort-desc.svg' : '/images/icons/sort-asc.svg'}}"
          mode="aspectFit"
        />
      </view>
    </view>
  </view>

  <!-- 分类筛选区 -->
  <scroll-view 
    class="category-scroll" 
    scroll-x 
    scroll-with-animation
    scroll-left="{{categoryScrollLeft}}"
  >
    <view class="category-list">
      <!-- 全部选项 -->
      <view 
        class="category-item {{activeCategory === 'all' ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-category="all"
      >
        <text class="category-text">全部</text>
      </view>
      
      <!-- 分类选项 -->
      <view 
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-category="{{item.id}}"
      >
        <text class="category-text">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 菜品列表区 -->
  <scroll-view 
    class="dish-scroll" 
    scroll-y 
    enable-back-to-top
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >
    <!-- 空状态 -->
    <view wx:if="{{isEmpty}}" class="empty-container">
      <image 
        class="empty-image" 
        src="/images/empty-dish.png"
        mode="aspectFit"
      />
      <view class="empty-text">快来添加第一道拿手好菜吧</view>
      <view class="empty-action">
        <button 
          class="btn btn-primary empty-btn"
          bindtap="onAddDishTap"
        >
          添加菜品
        </button>
      </view>
    </view>

    <!-- 加载中状态 -->
    <view wx:if="{{loading && !isEmpty}}" class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 网格视图 -->
    <view wx:if="{{viewMode === 'grid' && !isEmpty}}" class="grid-container">
      <view 
        wx:for="{{dishList}}"
        wx:key="_id"
        class="dish-grid-item"
        bindtap="onDishTap"
        data-dish="{{item}}"
        bindlongpress="onDishLongPress"
        data-index="{{index}}"
      >
        <!-- 菜品图片 -->
        <view class="dish-image-container">
          <image 
            class="dish-image" 
            src="{{item.imageUrl || '/images/default-dish.png'}}"
            mode="aspectFill"
            lazy-load="{{true}}"
            binderror="onImageError"
            bindload="onImageLoad"
            data-index="{{index}}"
          />
          <!-- 加载占位 -->
          <view class="image-placeholder" wx:if="{{!item.imageLoaded}}">
            <view class="placeholder-content"></view>
          </view>
        </view>
        
        <!-- 菜品信息 -->
        <view class="dish-info">
          <!-- 菜名 -->
          <view class="dish-name">
            <text class="name-text">{{item.name}}</text>
          </view>
          
          <!-- 分类标签 -->
          <view class="dish-tags">
            <view 
              wx:for="{{item.categories.slice(0, 2)}}"
              wx:key="index"
              class="dish-tag"
            >
              <text class="tag-text">{{item}}</text>
            </view>
            <text class="more-tag" wx:if="{{item.categories.length > 2}}">
              +{{item.categories.length - 2}}
            </text>
          </view>
        </view>
      </view>
    </view>

    <!-- 列表视图 -->
    <view wx:if="{{viewMode === 'list' && !isEmpty}}" class="list-container">
      <view 
        wx:for="{{dishList}}"
        wx:key="_id"
        class="dish-list-item"
        bindtap="onDishTap"
        data-dish="{{item}}"
        bindlongpress="onDishLongPress"
        data-index="{{index}}"
      >
        <!-- 左侧图片 -->
        <view class="list-image-container">
          <image 
            class="list-image" 
            src="{{item.imageUrl || '/images/default-dish.png'}}"
            mode="aspectFill"
            lazy-load="{{true}}"
          />
        </view>
        
        <!-- 右侧信息 -->
        <view class="list-info">
          <!-- 菜名 -->
          <view class="list-name">
            <text class="list-name-text">{{item.name}}</text>
          </view>
          
          <!-- 分类标签 -->
          <view class="list-tags">
            <view 
              wx:for="{{item.categories.slice(0, 2)}}"
              wx:key="index"
              class="list-tag"
            >
              <text class="list-tag-text">{{item}}</text>
            </view>
            <text class="more-tag" wx:if="{{item.categories.length > 2}}">
              +{{item.categories.length - 2}}
            </text>
          </view>
          
          <!-- 时间信息 -->
          <view class="list-time" wx:if="{{item.createTime}}">
            <text class="time-icon">🕐</text>
            <text class="time-text">{{formatTime(item.createTime)}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{hasMore && !loading && !isEmpty}}" class="load-more">
      <text class="load-more-text">上拉加载更多</text>
    </view>
    
    <view wx:if="{{!hasMore && !isEmpty}}" class="no-more">
      <text class="no-more-text">没有更多菜品了</text>
    </view>
  </scroll-view>

  <!-- 悬浮添加按钮 -->
  <view class="floating-action-btn" bindtap="onAddDishTap">
    <view class="fab-icon">+</view>
  </view>

  <!-- 操作菜单 -->
  <t-action-sheet
    visible="{{showActionSheet}}"
    items="{{actionItems}}"
    bind:close="onActionSheetClose"
    bind:selected="onActionSheetSelect"
  />

  <!-- 确认删除弹窗 -->
  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除这个菜品吗？删除后无法恢复。"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />
</view>