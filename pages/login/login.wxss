/* 登录页样式 */

page {
  background: linear-gradient(135deg, #FF6B35 0%, #FFA500 100%);
}

.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B35 0%, #FFA500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
  animation: float 6s ease-in-out infinite;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 200rpx;
  left: -80rpx;
  animation: float 8s ease-in-out infinite 1s;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  bottom: -50rpx;
  right: 100rpx;
  animation: float 10s ease-in-out infinite 2s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-30rpx) rotate(180deg);
  }
}

/* 主要内容区 */
.content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo和标题 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.6;
}

/* 用户信息卡片 */
.user-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像按钮 */
.avatar-btn {
  width: 160rpx;
  height: 200rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
}

.avatar-tip {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 昵称输入 */
.nickname-row {
  width: 100%;
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 32rpx 0 40rpx;
}

.nickname-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8B5C 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
  border: none;
}

.login-btn.disabled {
  background: #e0e0e0;
  color: #999999;
  box-shadow: none;
}

.login-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

/* 一键登录 */
.quick-login {
  width: 100%;
  margin-bottom: 40rpx;
}

/* 一键登录按钮（白色） */
.quick-login .login-btn {
  background: #ffffff;
  color: #FF6B35;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.quick-login .login-btn:active {
  background: #f5f5f5;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* 云端用户卡片 */
.cloud-user-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.cloud-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.cloud-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.cloud-tip {
  font-size: 24rpx;
  color: #999999;
}

/* 协议 */
.agreement {
  margin-top: 48rpx;
  text-align: center;
}

.agreement-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.link {
  color: #ffffff;
  text-decoration: underline;
}

/* 协议弹窗 */
.agreement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 85%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding-top: 32rpx;
  padding-left: 32rpx;
  padding-bottom: 32rpx;
  max-height: 60vh;
  box-sizing: border-box;
  overflow-y: auto;
}

.agreement-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  padding-right: 32rpx;
  padding-bottom: 32rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E5E5E5;
}

.modal-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #FF6B35;
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 12rpx;
}
