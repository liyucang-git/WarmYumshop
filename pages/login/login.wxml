<!-- 暖圆小铺 - 登录页 -->
<view class="page-container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <!-- 主要内容区 -->
  <view class="content">
    <!-- Logo和标题 -->
    <view class="logo-section">
      <image class="logo-image" src="/images/暖圆小铺.jpeg" mode="aspectFill" />
      <view class="app-name">暖圆小铺</view>
      <view class="app-slogan">记录家庭美味，留住幸福时光</view>
    </view>

    <!-- 新用户：填写信息 -->
    <view class="user-card" wx:if="{{needFillInfo}}">
      <!-- 头像 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="avatar-tip">点击选择头像</view>
      </button>

      <!-- 昵称 -->
      <view class="nickname-row">
        <text class="nickname-label">昵称</text>
        <input 
          class="nickname-input" 
          type="nickname" 
          placeholder="点击获取微信昵称" 
          value="{{nickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
        />
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-btn {{canLogin ? '' : 'disabled'}}" 
        bindtap="onLogin"
        disabled="{{!canLogin}}"
      >
        <text>{{loading ? '登录中...' : '进入暖圆小铺'}}</text>
      </button>
    </view>

    <!-- 老用户：一键登录（显示之前保存的信息） -->
    <view class="quick-login" wx:elif="{{hasCloudUser}}">
      <view class="cloud-user-card">
        <image 
          class="cloud-avatar" 
          src="{{cloudUserInfo.avatarUrl || '/images/default-avatar.png'}}" 
          mode="aspectFill" 
        />
        <view class="cloud-nickname">{{cloudUserInfo.nickname || '用户'}}</view>
        <view class="cloud-tip">点击下方按钮直接登录</view>
      </view>
      <button 
        class="login-btn" 
        bindtap="onQuickLogin"
        loading="{{loading}}"
      >
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </button>
    </view>

    <!-- 本地缓存用户：一键登录 -->
    <view class="quick-login" wx:elif="{{!needFillInfo && !hasCloudUser}}">
      <button 
        class="login-btn" 
        bindtap="onQuickLogin"
        loading="{{loading}}"
      >
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </button>
    </view>

    <!-- 协议 -->
    <view class="agreement">
      <text class="agreement-text">
        登录即表示同意
        <text class="link" bindtap="onAgreementTap" data-type="user">《用户协议》</text>
        和
        <text class="link" bindtap="onAgreementTap" data-type="privacy">《隐私政策》</text>
      </text>
    </view>

    <!-- 协议弹窗 -->
    <view class="agreement-modal" wx:if="{{showAgreementModal}}">
      <view class="modal-content">
        <view class="modal-header">
          <view class="modal-title">{{agreementTitle}}</view>
          <view class="modal-close" bindtap="onCloseModal">×</view>
        </view>
        <scroll-view class="modal-body" scroll-y>
          <view class="agreement-content">{{agreementContent}}</view>
        </scroll-view>
        <view class="modal-footer">
          <view class="modal-btn" bindtap="onCloseModal">我知道了</view>
        </view>
      </view>
    </view>
  </view>
</view>
